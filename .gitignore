# Build / IDE / system

/.bsp/
/.idea/
/project/target/
/target/
*/target/
*/task-temp-directory/
/project/project/
/doc/.obsidian
/doc/.obsidian/
book/
/book
.obsidian
.smart-env
**/.DS_Store
/inventory/

# Binary documents — internal artefacts, never commit
# Recursive glob covers root + every subdirectory.
**/*.pdf
**/*.pptx
**/*.ppt
**/*.doc
**/*.docx
**/*.xlsx
**/*.xls
**/*.zip
**/*.tar.gz
**/*.tgz
**/*.7z
**/*.rar

# (If you ever genuinely need a single tracked binary,
#  use `git add -f <path>` to override.)
